{
  "name": "openharness-ts",
  "version": "0.1.0",
  "description": "TypeScript implementation of OpenHarness-style agent harness infrastructure.",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openharness": "./dist/cli/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b src",
    "clean": "rimraf dist .tsbuild coverage",
    "test": "vitest run --exclude \"test/{deepseek.integration,cli-built-acceptance,tui-deepseek.integration}.test.{ts,tsx}\"",
    "test:cli-built": "vitest run test/cli-built-acceptance.test.ts",
    "test:deepseek": "vitest run test/deepseek.integration.test.ts",
    "test:tui-deepseek": "vitest run test/tui-deepseek.integration.test.tsx",
    "test:tui-acceptance": "vitest run test/tui-acceptance.test.tsx test/tui-terminal.test.ts test/tui-fixture-renderer.test.ts test/tui-shell.test.tsx",
    "test:watch": "vitest",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "rimraf": "^5.0.10",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0",
    "ink": "^6.8.0",
    "openai": "^6.42.0",
    "react": "^19.2.7",
    "tinyglobby": "^0.2.17"
  }
}
